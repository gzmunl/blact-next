generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model BlogPost {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  excerpt         String
  image           String
  category        String
  categorySlug    String
  date            DateTime
  readTime        Int      @default(5)
  content         String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  seoScore        Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model NewsPost {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  title           String
  excerpt         String
  image           String
  category        String
  categorySlug    String
  date            DateTime
  content         String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  seoScore        Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admin {
  id           Int    @id @default(autoincrement())
  email        String @unique
  passwordHash String
}
